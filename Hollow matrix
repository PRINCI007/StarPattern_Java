class Main {
    public static void main(String[] args) {
        int num=1;
        
        for(int i=0;i<3;i++){
            for(int j=0;j<3;j++){
              if(i==1 && j==1){
                  System.out.print("  ");
              }
              else{
                  System.out.print(num+ " ");
                  num++;
              }
               
            }
            System.out.println();
        }
    }
}


output: 
1 2 3 
4   5 
6 7 8 

